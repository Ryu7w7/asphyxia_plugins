//DATA//
  rivals: DB.Find(refid, { collection: 'rival' })
  yourprofile: DB.Find(refid, { collection: 'profile' })
  profiles: DB.Find(null, { collection: 'profile' })
-
link(rel="stylesheet" href="static/asset/css/datatables.css")

style.
  /* Ensure DataTables matches the Modern theme */
  .dataTables_wrapper .dataTables_filter input {
    background: var(--panel2) !important;
    border: 1px solid var(--border) !important;
    border-radius: var(--radius-xs) !important;
    color: var(--text) !important;
    padding: 0.5rem 1rem !important;
  }
  .dataTables_wrapper .dataTables_length select {
    background: var(--panel2) !important;
    border: 1px solid var(--border) !important;
    color: var(--text) !important;
    border-radius: var(--radius-xs) !important;
  }
  .dataTables_wrapper .dataTables_info, 
  .dataTables_wrapper .dataTables_paginate {
    color: var(--muted) !important;
    font-size: 0.85rem;
  }
  .table-container {
    background: rgba(0,0,0,0.15);
    padding: 1rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  .table thead th {
    color: var(--accent) !important;
    border-bottom: 2px solid var(--border) !important;
  }
  .table td {
    vertical-align: middle !important;
  }
  .button.is-primary.is-small {
    background: linear-gradient(135deg, var(--accent), var(--accent2)) !important;
    border: none;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
  }
  .button.is-danger.is-light.is-small {
    background: rgba(239, 68, 68, 0.15) !important;
    border: 1px solid rgba(239, 68, 68, 0.3) !important;
    color: #ff6b6b !important;
  }
  
div
  .card
    .card-header
      p.card-header-title
        span.icon
          i.mdi.mdi-account-multiple
        | Player Directory
    .card-content
      .columns.is-vcentered.mb-4
        .column.is-4
          .field
            label.label.is-small Game Version
            .control.has-icons-left
              span.select.is-fullwidth.is-rounded
                select(id="version_select")
              span.icon.is-small.is-left
                i.mdi.mdi-gamepad-variant
        .column
          .notification.is-info.is-light.p-2.is-size-7
            span.icon
              i.mdi.mdi-information-outline
            | Use the search box below to find players by name.

      .table-container
        table.table.is-fullwidth.is-hoverable#player-table(style="width: 100%")
          thead
            tr
              th Player Name
              th.has-text-centered Action
          tbody
            // Handled by rivals.js

  .card.mt-5
    .card-header
      p.card-header-title
        span.icon
          i.mdi.mdi-chart-bar
        | Score Comparison
    .card-content
      .field
        label.label.is-small Select a rival to compare scores
        .control.has-icons-left
          span.select.is-fullwidth.is-rounded
            select(id="rivallist")
              option(value=0) -- Select Active Rival --
          span.icon.is-small.is-left
            i.mdi.mdi-account-star

      .table-container.mt-5
        table.table.is-hoverable.is-fullwidth#scorecompare(style="width: 100%")
          thead
            tr    
              th ID
              th Song Title
              th Level
              th Your Score
              th Rival Score
              th Date
          tbody

div(hidden id='rivals-pass') !{JSON.stringify(rivals)}
div(hidden id='profile-pass') !{JSON.stringify(yourprofile)}
div(hidden id='profiles-pass') !{JSON.stringify(profiles)}
div(hidden id='refid-pass') !{refid}
script(src="static/asset/js/rivals.js?v=2")
script(src="static/asset/js/datatables.js")